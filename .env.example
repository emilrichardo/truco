# Cargá estos mismos nombres en Vercel → Project Settings → Environment Variables.
# Marcá NEXT_PUBLIC_* como "Exposed to browser". El service_role NO debe ir a Vercel
# (solo se usa para migraciones desde tu máquina y desde Edge Functions).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local-only: para correr migraciones contra tu DB.
SUPABASE_SERVICE_ROLE_KEY=
